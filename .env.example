# ============ Google Gemini ============
# 从 https://aistudio.google.com/apikey 获取
GEMINI_API_KEY=your_gemini_api_key_here

# ============ LLM 供应商切换（可选）============
# gemini（默认，有免费额度）| deepseek（更便宜约 9 倍，需充值）
LLM_PROVIDER=gemini
# 仅当 LLM_PROVIDER=deepseek 时需要；从 https://platform.deepseek.com/api_keys 获取
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ============ 邮件 SMTP ============
# Gmail 示例：需先开启两步验证并生成“应用专用密码”(App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_account@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_USE_SSL=true
MAIL_FROM=your_account@gmail.com
MAIL_TO=recipient1@example.com,recipient2@example.com
MAIL_SUBJECT_PREFIX=每日外媒新闻简报

# ============ 运行控制 ============
LOG_LEVEL=INFO
# once = 执行一次后退出(默认，适合 GitHub Actions)；schedule = 常驻定时(适合 Docker)
RUN_MODE=once
CONFIG_PATH=config.yaml
RUN_ON_START=false

# ============ 网络 / SSL（一般无需设置）============
# 仅当在“公司网络 SSL 拦截”下本地测试报 CERTIFICATE_VERIFY_FAILED 时才需要：
# 推荐（安全）：指向公司根证书 PEM 文件
# CA_BUNDLE=C:\path\to\corporate-root-ca.pem
# 或（不安全，仅本地临时测试用）：关闭证书校验
# VERIFY_SSL=false

# ============ Notion 个人知识库同步（可选，免费）============
# 在 https://www.notion.so/my-integrations 建 Integration 拿 secret；
# 建一个父页面并把该 Integration 分享给它，页面 URL 末尾的 32 位即 page id。
# NOTION_TOKEN=secret_xxx
# NOTION_PARENT_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOTION_SYNC_ENABLED=true
